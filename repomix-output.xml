  align-items: center;
  justify-content: center;
  color: rgba(0, 29, 61, 0.55);
  background:
    radial-gradient(320px 200px at 20% 20%, rgba(255, 195, 0, 0.14), transparent 60%),
    radial-gradient(260px 180px at 80% 10%, rgba(0, 53, 102, 0.16), transparent 60%),
    linear-gradient(135deg, rgba(250, 250, 248, 1), rgba(255, 255, 255, 1));
}
.detail-badges {
  display: flex;
  gap: 0.6rem;
  flex-wrap: wrap;
  margin: 1.1rem 0 0.7rem;
}
.detail-status {
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: 1px solid rgba(0, 0, 0, 0.08);
}
.detail-cat {
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  font-size: 0.68rem;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: 1px solid rgba(255, 195, 0, 0.35);
  background: rgba(255, 195, 0, 0.12);
  color: rgba(0, 29, 61, 0.85);
}
.detail-title {
  margin: 0.35rem 0 0.7rem;
  font-size: clamp(1.6rem, 2.8vw, 2.25rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  color: var(--ink-black);
  text-transform: uppercase;
}
.detail-specs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.8rem;
  margin: 1rem 0 1rem;
}
.spec {
  border-radius: 14px;
  border: 1px solid rgba(0, 53, 102, 0.10);
  background: rgba(250, 250, 248, 0.85);
  padding: 0.9rem;
}
.spec-k {
  font-size: 0.70rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(0, 29, 61, 0.55);
}
.spec-v {
  margin-top: 0.35rem;
  font-weight: 900;
  color: rgba(0, 29, 61, 0.92);
  letter-spacing: -0.01em;
}
.detail-price {
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--oxford);
  letter-spacing: -0.02em;
  margin: 0.25rem 0 1rem;
}
.detail-desc {
  border-radius: 16px;
  background: var(--white);
  border: 1px solid rgba(0, 53, 102, 0.10);
  box-shadow: 0 18px 44px rgba(0, 29, 61, 0.06);
  padding: 1.2rem;
}
.detail-section-title {
  font-size: 0.78rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(0, 29, 61, 0.72);
  margin-bottom: 0.6rem;
}
.detail-desc p {
  margin: 0;
  color: #64748b;
  line-height: 1.8;
}
.carbon-card {
  margin-top: 1rem;
  border-radius: 16px;
  border: 1px solid rgba(255, 195, 0, 0.30);
  background: rgba(255, 195, 0, 0.12);
  padding: 1.1rem 1.2rem;
}
.carbon-kicker {
  font-size: 0.70rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(0, 29, 61, 0.7);
}
.carbon-text {
  margin-top: 0.5rem;
  font-size: 1rem;
  color: rgba(0, 29, 61, 0.85);
  line-height: 1.65;
}
.carbon-sub {
  margin-top: 0.35rem;
  font-size: 0.86rem;
  color: rgba(0, 29, 61, 0.55);
}
.detail-section {
  margin-top: 1rem;
}
.seller-row {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(220px, 260px);
  gap: 0.8rem;
  overflow-x: auto;
  padding-bottom: 0.4rem;
}
.mini-card {
  text-decoration: none;
  border-radius: 16px;
  border: 1px solid rgba(0, 53, 102, 0.10);
  background: var(--white);
  box-shadow: 0 18px 44px rgba(0, 29, 61, 0.06);
  overflow: hidden;
  color: inherit;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.mini-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 26px 64px rgba(0, 29, 61, 0.10);
}
.mini-thumb {
  height: 96px;
  background: linear-gradient(135deg, rgba(0, 29, 61, 0.12), rgba(255, 195, 0, 0.10));
}
.mini-body {
  padding: 0.9rem;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}
.mini-title {
  font-weight: 900;
  color: rgba(0, 29, 61, 0.95);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.mini-meta {
  font-size: 0.82rem;
  color: rgba(0, 29, 61, 0.55);
}
.mini-price {
  font-weight: 900;
  color: var(--oxford);
}
.detail-muted {
  color: #64748b;
}
.detail-right {
  position: sticky;
  top: calc(var(--nav-height) + 1.1rem);
}
.seller-card {
  border-radius: 18px;
  background: var(--white);
  border: 1px solid rgba(0, 53, 102, 0.10);
  box-shadow: 0 18px 44px rgba(0, 29, 61, 0.06);
  padding: 1.25rem;
}
.seller-top {
  display: flex;
  gap: 0.9rem;
  align-items: center;
}
.seller-avatar {
  width: 46px;
  height: 46px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--prussian), var(--oxford));
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
}
.seller-name {
  font-weight: 900;
  color: rgba(0, 29, 61, 0.95);
}
.seller-meta {
  margin-top: 0.2rem;
  color: rgba(0, 29, 61, 0.55);
  font-size: 0.86rem;
}
.seller-trust {
  margin-top: 1rem;
  padding-top: 1rem;
  border-top: 1px solid rgba(0, 53, 102, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.trust-k {
  font-size: 0.72rem;
  font-weight: 900;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(0, 29, 61, 0.55);
}
.trust-v {
  font-weight: 900;
  color: rgba(0, 29, 61, 0.92);
}
.seller-cta {
  width: 100%;
  margin-top: 0.8rem;
}
.seller-note {
  margin-top: 1rem;
  color: #64748b;
  line-height: 1.7;
  font-size: 0.9rem;
}
@media (max-width: 1024px) {

  .market-layout {
    grid-template-columns: 1fr;
  }

  .filter-card {
    position: relative;
    top: unset;
  }

  .listing-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .detail-layout {
    grid-template-columns: 1fr;
  }

  .detail-right {
    position: relative;
    top: unset;
  }

  .detail-specs {
    grid-template-columns: 1fr;
  }
}
@media (max-width: 768px) {

  .market-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .market-head-right {
    width: 100%;
    justify-content: flex-start;
  }

  .listing-grid {
    grid-template-columns: 1fr;
  }

  .filter-card {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 1.25rem;
    padding: 1rem;
  }
  
  .filter-head {
    grid-column: 1 / -1;
    margin-bottom: 0;
  }
  
  .filter-section {
    padding: 0.5rem 0;
    border-top: none;
    border-bottom: 1px solid rgba(0, 53, 102, 0.04);
  }
  
  .filter-reset-btn {
    grid-column: 1 / -1;
    margin-top: 0.5rem;
    padding: 0.7rem 1rem;
  }
}

@media (max-width: 425px) {

  .market-shell {
    padding-left: 5%;
    padding-right: 5%;
  }

  .market-sort {
    min-width: unset;
    width: 100%;
  }

  .market-head-right {
    flex-direction: column;
    align-items: stretch;
  }

  .dd-root {
    width: 100%;
  }

  .market-dropdown-btn {
    width: 100%;
  }

  .detail-gallery {
    height: 240px;
  }

  .filter-card {
    grid-template-columns: repeat(2, 1fr);
    gap: 0.25rem 0.8rem;
    padding: 0.8rem;
  }

  .filter-label {
    margin-bottom: 0.4rem;
    font-size: 0.65rem;
  }

  .filter-options {
    gap: 0.35rem;
  }

  .check, .radio {
    font-size: 0.78rem;
    gap: 0.4rem;
  }

  .check input, .radio input {
    width: 14px;
    height: 14px;
  }

  .range-readout {
    font-size: 0.75rem;
  }

  .detail-specs {
    grid-template-columns: 1fr;
  }

  .seller-card {
    padding: 1rem;
  }
}
