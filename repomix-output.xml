  color: rgba(255, 255, 255, 0.45);
  margin-top: 0.35rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
/* ── Scroll indicator ── */
.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  margin: 0;
  padding: 0.5rem 0.75rem;
