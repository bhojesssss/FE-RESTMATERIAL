  }

  .dash-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .dash-actions {
    justify-content: flex-start;
  }

  .create-row {
    grid-template-columns: 1fr;
  }

  .market-head {
    flex-direction: column;
    align-items: flex-start;
  }

  .market-head-right {
    width: 100%;
    justify-content: flex-start;
  }

  .listing-grid {
    grid-template-columns: 1fr;
  }
}
